{
  "name": "goose-note",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "description": "A local-first, Notion-style note-taking app — a uTools plugin (also browser-runnable) built on the BlockNote block editor with built-in AI.",
  "license": "MIT",
  "homepage": "https://github.com/eachann1024/goose-notes#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/eachann1024/goose-notes.git"
  },
  "bugs": {
    "url": "https://github.com/eachann1024/goose-notes/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite  --port 6001",
    "build": "tsc -b && vite build && GOOSE_BUILD_TARGET=quicknote vite build && node scripts/utools-build.js",
    "build:debug": "GOOSE_DEBUG=1 tsc -b && GOOSE_DEBUG=1 vite build && GOOSE_DEBUG=1 GOOSE_BUILD_TARGET=quicknote vite build && GOOSE_DEBUG=1 node scripts/utools-build.js",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test:unit": "playwright test -c playwright.unit.config.ts",
    "test:e2e": "E2E_AUTO_START=1 playwright test",
    "test:e2e:headed": "E2E_AUTO_START=1 PW_HEADED=1 playwright test",
    "test:e2e:ui": "E2E_AUTO_START=1 playwright test --ui",
    "test:e2e:report": "playwright show-report output/playwright/report",
    "test:e2e:codegen": "playwright codegen http://localhost:6001"
  },
  "dependencies": {
